    "lhci": "npm run lhci:collect && npm run lhci:append"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.3",
    "node-fetch": "^3.3.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^6.7.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@lhci/cli": "^0.14.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
