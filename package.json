{
  "name": "foo-depart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lhci:collect": "lhci collect --url=https://depart.fredriketsare.se --numberOfRuns=1 --outputDir=.lighthouseci --settings.chromeFlags='--no-sandbox --disable-dev-shm-usage'",
