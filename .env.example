# Required: Trafiklab/Resrobot API
RESROBOT_ACCESS_ID=your_resrobot_access_id # https://www.trafiklab.se/api/our-apis/resrobot-v21
RESROBOT_API_BASE_URL=https://api.resrobot.se/v2.1/departureBoard
API_DURATION=120

# Required for contact/inquiry flow
RESEND_API_KEY=your_resend_api_key
JWT_SECRET=replace_with_a_long_random_secret  # e.g. use this: node -e "console.log(require('crypto').randomBytes(256).toString('base64'));"
ADMIN_EMAIL=you@example.com

# Required for GitHub issue/branch automation
GITHUB_TOKEN=ghp_your_github_token
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=foo-depart
GITHUB_BASE_BRANCH=main

# Canonical public site URL (used for sitemap and internal app URL generation)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public GitHub links used in UI
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/your-github-username-or-org/foo-depart
NEXT_PUBLIC_GITHUB_BADGE_REPO=your-github-username-or-org/foo-depart

# Public UI tuning
NEXT_PUBLIC_DEFAULT_MIN_TIME_THRESHOLD=7
NEXT_PUBLIC_MAX_DEPARTURES_TO_DISPLAY=10

# Optional email signature used in approval/rejection replies
CONTACT_SIGNATURE_NAME=Ugla
